# Copiá este archivo a .env y completá el valor. Vite lo inyecta en el build.

# URL del Apps Script web app que respalda en Google Sheets (termina en /exec).
# Lo obtenés al deployar apps-script/Code.gs (ver instrucciones en ese archivo).
# Es la única variable necesaria, y es la misma para todos los dispositivos.
VITE_SHEETS_ENDPOINT=
