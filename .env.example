# Copiá este archivo a .env y completá los valores. Vite los inyecta en el build.
# Ninguno es secreto: el Client ID es público en apps de navegador y el ID de la
# planilla solo sirve si tenés acceso a esa planilla en Drive.

# OAuth Client ID de Google (termina en .apps.googleusercontent.com).
# Lo sacás de console.cloud.google.com → Credenciales. Único requisito obligatorio.
VITE_GOOGLE_CLIENT_ID=

# ID de la planilla de respaldo. Dejalo VACÍO la primera vez: la app crea la
# planilla sola en tu Drive y te muestra su ID en un cartelito. Pegá ese ID acá
# (y redeploy) para que todos los dispositivos usen esa misma planilla.
VITE_BACKUP_SPREADSHEET_ID=
