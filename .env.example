# Copiá este archivo a .env y completá los valores. Vite los inyecta en el build.
# Ninguno es secreto: el Client ID es público en apps de navegador y el ID de la
# planilla solo sirve si tenés acceso a esa planilla en Drive.

# OAuth Client ID de Google (termina en .apps.googleusercontent.com).
# Lo sacás de console.cloud.google.com → Credenciales. Fija la app para todos.
VITE_GOOGLE_CLIENT_ID=

# ID de la planilla compartida de respaldo (lo que va en la URL de la planilla,
# entre /d/ y /edit). Dejalo vacío la primera vez: conectá una vez con la cuenta
# compartida, la app crea la planilla y te muestra el ID para pegarlo acá.
VITE_BACKUP_SPREADSHEET_ID=
